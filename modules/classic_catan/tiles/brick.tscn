[sub_resource type="GDScript" id="GDScript_smoke_day"]
script/source = "extends GPUParticles3D
# Fumée du four : émet le JOUR. Le vent (Weather.wind_vector()) la fait dériver horizontalement.

var _rise := 0.0

func _ready() -> void:
	if process_material != null:
		_rise = process_material.gravity.y
	DayNight.cycle_changed.connect(_refresh)
	_refresh()

func _refresh() -> void:
	emitting = DayNight.day_factor >= 0.5
	if process_material != null:
		var w := Weather.wind_vector()
		process_material.gravity = Vector3(w.x, _rise, w.z)
"

