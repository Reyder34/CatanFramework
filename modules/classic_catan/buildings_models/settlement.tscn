[sub_resource type="GDScript" id="GDScript_smoke_night"]
script/source = "extends GPUParticles3D
# Fumée de cheminée : émet la NUIT. Le vent (Weather.wind_vector()) la fait dériver horizontalement.

var _rise := 0.0

func _ready() -> void:
	if process_material != null:
		_rise = process_material.gravity.y
	DayNight.cycle_changed.connect(_refresh)
	_refresh()

func _refresh() -> void:
	emitting = Settings.smoke_enabled and DayNight.day_factor < 0.5
	if process_material != null:
		var w := Weather.wind_vector()
		process_material.gravity = Vector3(w.x, _rise, w.z)
"

